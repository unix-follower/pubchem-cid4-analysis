{
  "name": "cid4-angular-ui",
  "version": "1.0.0-SNAPSHOT",
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:cid4-angular-ui": "node dist/cid4-angular-ui/server/server.mjs",
    "lint": "eslint",
    "check-format": "prettier --log-level error --check '**/*.{js,jsx,ts,tsx,cjs,mjs,json,css,html}'",
    "format": "prettier --log-level error --write '**/*.{js,jsx,ts,tsx,cjs,mjs,json,css,html}'"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.3",
    "@tanstack/angular-query-experimental": "^5.96.0",
    "@tanstack/query-core": "^5.96.0",
    "3dmol": "^2.5.4",
    "cytoscape": "^3.33.1",
    "express": "^5.1.0",
    "msw": "^2.12.14",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^7.5.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
